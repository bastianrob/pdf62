{
  "name": "@pdf62/web",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "pnpm prep:pdfjs && next dev",
    "build": "pnpm prep:pdfjs && next build",
    "build:static": "pnpm prep:wasm && DEPLOY_MODE=static pnpm build",
    "prep:wasm": "cp ../../packages/engine/dist/processor.wasm ./public/processor.wasm",
    "prep:pdfjs": "rm -rf ./public/pdfjs ./public/pdfjs.worker.min.mjs && mkdir -p ./public/pdfjs && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs ./public/pdfjs.worker.min.mjs && cp -R node_modules/pdfjs-dist/wasm node_modules/pdfjs-dist/cmaps node_modules/pdfjs-dist/iccs node_modules/pdfjs-dist/standard_fonts ./public/pdfjs/",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@next/third-parties": "16.2.6",
    "@pdf62/ui": "workspace:*",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "pdfjs-dist": "6.1.200",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "tailwindcss": "4.0.0-alpha.15"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5"
  }
}
